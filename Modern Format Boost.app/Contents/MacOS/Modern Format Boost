#!/bin/zsh
# Modern Format Boost - macOS App Wrapper
#
# Entry point using zsh (system default shell); supports drag-and-drop or double-click folder selection

# Get app bundle path (zsh: $0 is script path)
APP_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
PROJECT_ROOT="$(dirname "$APP_DIR")"
PROCESSOR_SCRIPT="$PROJECT_ROOT/scripts/drag_and_drop_processor.sh"

# Check if processor script exists
if [[ ! -f "$PROCESSOR_SCRIPT" ]]; then
    osascript -e 'display alert "Error" message "Processor script not found. Please ensure Modern Format Boost is fully installed." as critical'
    exit 1
fi

# If arguments provided (drag mode), run processor in new Terminal window; this script exits to avoid empty window
if [[ $# -gt 0 ]]; then
    (
        osascript <<EOF
tell application "Terminal"
    do script "cd '$PROJECT_ROOT' && export FROM_APP=1 && '$PROCESSOR_SCRIPT' '$1'; echo 'Press any key to close...'; read -n 1"
    activate
end tell
EOF
    ) &
    exit 0
else
    # Double-click mode: folder selection with 30-minute timeout
    TIMEOUT_SEC=1800
    TMPOUT=$(mktemp 2>/dev/null || echo "/tmp/mfb_choose_$$.txt")
    osascript -e 'POSIX path of (choose folder with prompt "Select folder to process (30-minute timeout):")' > "$TMPOUT" 2>/dev/null &
    OPID=$!
    for ((i = 0; i < TIMEOUT_SEC; i++)); do
        if ! kill -0 "$OPID" 2>/dev/null; then
            break
        fi
        sleep 1
    done
    if kill -0 "$OPID" 2>/dev/null; then
        kill "$OPID" 2>/dev/null
        wait "$OPID" 2>/dev/null
        rm -f "$TMPOUT"
        osascript -e 'display alert "Timeout" message "Folder selection cancelled (no action for 30 minutes)." as critical'
        exit 0
    fi
    SELECTED_DIR=$(cat "$TMPOUT" 2>/dev/null)
    rm -f "$TMPOUT"
    if [[ -z "$SELECTED_DIR" ]]; then
        exit 0
    fi
    SELECTED_DIR="${SELECTED_DIR%/}"

    # Safety confirmation: show path to be processed, 30-minute timeout; only execute if user clicks "Start"
    TMPCONF=$(mktemp 2>/dev/null || echo "/tmp/mfb_confirm_$$.txt")
    osascript -e "display dialog \"Will optimize the following folder:\n\n$SELECTED_DIR\" with title \"Modern Format Boost\" buttons {\"Cancel\", \"Start Optimization\"} default button 2 cancel button 1 with icon caution" > "$TMPCONF" 2>/dev/null &
    CPID=$!
    for ((j = 0; j < TIMEOUT_SEC; j++)); do
        if ! kill -0 "$CPID" 2>/dev/null; then
            break
        fi
        sleep 1
    done
    if kill -0 "$CPID" 2>/dev/null; then
        kill "$CPID" 2>/dev/null
        wait "$CPID" 2>/dev/null
        rm -f "$TMPCONF"
        osascript -e 'display alert "Timeout" message "Confirmation dialog closed (no action for 30 minutes)." as critical'
        exit 0
    fi
    CONFRES=$(cat "$TMPCONF" 2>/dev/null)
    rm -f "$TMPCONF"
    if [[ "$CONFRES" == *"Start Optimization"* ]]; then
        # Execute osascript in background and exit immediately, so system-opened empty terminal only has shell, no "terminate running process" prompt on close
        (
            osascript <<EOF
tell application "Terminal"
    do script "cd '$PROJECT_ROOT' && export FROM_APP=1 && '$PROCESSOR_SCRIPT' '$SELECTED_DIR'"
    activate
end tell
EOF
        ) &
        exit 0
    fi
fi